# MedBridge Configuration
# Copy this to .env and adjust as needed

# Embedding model (auto-downloaded from HuggingFace)
HARRIER_MODEL_NAME=microsoft/harrier-oss-v1-0.6b

# Database paths (auto-created)
QDRANT_PATH=data/qdrant
FALKORDB_PATH=data/falkordb

# LLM server (llama-server OpenAI-compatible API)
# Start with: llama-server -hf ggml-org/gemma-4-E2B-it-GGUF:Q4_K_M
LLM_API_BASE=http://localhost:8080/v1
LLM_MODEL_NAME=gemma-4
LLM_TEMPERATURE=0.7

# Embedding settings
EMBEDDING_DEVICE=mps
EMBEDDING_BATCH_SIZE=32
