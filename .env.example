# MedBridge Configuration
# Copy this to .env and adjust paths as needed

# Model paths (auto-downloaded by scripts/download_models.py)
HARRIER_MODEL_NAME=microsoft/harrier-oss-v1-0.6b
GEMMA_MODEL_PATH=data/models/gemma-4-E2B-it-Q4_K_M.gguf

# Database paths (auto-created)
QDRANT_PATH=data/qdrant
FALKORDB_PATH=data/falkordb

# LLM settings
LLM_N_GPU_LAYERS=-1
LLM_N_CTX=8192
LLM_TEMPERATURE=0.7

# Embedding settings
EMBEDDING_DEVICE=mps
EMBEDDING_BATCH_SIZE=32
